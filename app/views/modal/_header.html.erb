<div class="modal fade" id="headerModal">
  <div class="modal-dialog">
    <div class="modal-content p-3">

      <%= form_with model: @profile, url: cv_path(@profile), method: :patch do |f| %>
        <%= f.text_field :full_name, class: "form-control mb-2" %>
        <%= f.text_field :title, class: "form-control mb-2" %>

        <%= f.submit "Save", class: "btn btn-dark" %>
      <% end %>

    </div>
  </div>
</div>