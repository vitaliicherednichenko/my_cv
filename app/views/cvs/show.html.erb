<div class="container">
  <div class="row min-vh-100">


    <div class="text-center text-white text-uppercase py-3 bg-dark">
      <div class="d-flex justify-content-end">
        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#headerModal">Edit</button>
      </div>
      <h1 class="mb-3"><%= @profile.full_name %></h1>
      <h2><%= @profile.title %></h2>
    </div>

    <!-- LEFT SIDEBAR -->
    <div class="col-md-4 text-white left-sidebar">
      <div class="d-flex justify-content-between align-items-center mt-5">
        <h3 class="text-uppercase mb-0">Contact</h3>
        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#contactModal">
          Edit
        </button>
      </div>
      <hr class="bg-light" style="height: 5px;">
      <div>
        <% if @profile.phone %>
          <p><i class="bi bi-telephone"></i> &nbsp; <%= @profile.phone %></p>
        <% end %>
        <% if @profile.email %>
          <p><i class="bi bi-envelope-open"></i> &nbsp; <%= @profile.email %></p>
        <% end %>
        <% if @profile.location %>
          <p><i class="bi bi-pin-map"></i> &nbsp; <%= @profile.location %></p>
        <% end %>
        <% if @profile.github_url %>
          <p><i class="bi bi-github"></i> &nbsp; <%= @profile.github_url %></p>
        <% end %>
        <% if @profile.linkedin_url %>
          <p><i class="bi bi-linkedin"></i> &nbsp; <%= @profile.linkedin_url %></p>
        <% end %>
      </div>

      <!-- PROFILE -->
      <div class="d-flex justify-content-between align-items-center mt-5">
        <h3 class="text-uppercase mb-0">Profile</h3>
        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#profileModal">
          Edit
        </button>
      </div>
      <hr class="bg-light" style="height: 5px;">

      <p><%= @profile.summary %></p>

      <!-- SKILLS -->
      <div class="d-flex justify-content-between align-items-center mt-5">
        <h3 class="text-uppercase mb-0">Skills</h3>
        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#skillsModal">
          Edit
        </button>
      </div>
      <hr class="bg-light" style="height: 5px;">

      <% @skills.each do |skill| %>
        <div class="mb-2">
          <small><%= skill.name %></small>
          <div class="progress" style="height: 6px;">
            <div class="progress-bar bg-light" style="width: <%= skill.level %>%"></div>
          </div>
        </div>
      <% end %>

      <% if @languages.any? %>
        <!-- LANGUAGES -->
        <div class="d-flex justify-content-between align-items-center mt-5">
          <h3 class="text-uppercase mb-0">Languages</h3>
          <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#languagesModal">
            Edit
          </button>
        </div>
        <hr class="bg-light" style="height: 5px;">

        <% @languages.each do |lang| %>
          <p><%= lang.name %> — <%= lang.level %></p>
        <% end %>
      <% end %>
    </div>

    <!-- RIGHT CONTENT -->
    <div class="col-md-8 p-5 pt-4">

      <!-- EXPERIENCE -->
      <div class="d-flex justify-content-between align-items-center bg-dark p-4 mb-2">
        <h3 class="text-white text-uppercase mb-0">Experience</h3>

        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#newExperienceModal">
          Add
        </button>
      </div>

      <% if @experiences.any? %>
        <% @experiences.each do |exp| %>
          <div class="mb-4">
            <div class="d-flex justify-content-between">
              <h5 class="mb-1">
                <i class="bi bi-check-lg"></i>
                <strong><%= exp.position %></strong>
              </h5>

              <small class="text-muted">
                <%= exp.start_date.strftime("%b %Y") %> -
                <%= exp.current ? "Present" : exp.end_date&.strftime("%b %Y") %>
              </small>
            </div>

            <div class="d-flex justify-content-between align-items-center">
              <p class="text-muted mb-1">
                <%= exp.company_name %> — <%= exp.location %>
              </p>

              <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#experienceModal-<%= exp.id %>">
                Edit
              </button>
            </div>

            <ul>
              <% exp.experience_items.each do |item| %>
                <li><%= item.content %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
      <% else %>
        <p class="p-3 text-muted">No experience yet</p>
      <% end %>

      <!-- PROJECTS -->
      <div class="d-flex justify-content-between align-items-center bg-dark p-4 mb-2">
        <h3 class="text-white text-uppercase mb-0">Projects</h3>

        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#newProjectModal">
          Add
        </button>
      </div>

      <% if @projects.any? %>
        <% @projects.each do |project| %>
          <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center">
              <h5><%= project.name %></h5>

              <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#projectModal-<%= project.id %>">
                Edit
              </button>
            </div>

            <p><%= project.description %></p>

            <% if project.github_url.present? %>
              <div><%= project.github_url %></div>
            <% end %>

            <% if project.live_url.present? %>
              <div><%= project.live_url %></div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p class="p-3 text-muted">No projects yet</p>
      <% end %>

      <!-- CERTIFICATES -->
      <div class="d-flex justify-content-between align-items-center bg-dark p-4 mb-2">
        <h3 class="text-white text-uppercase mb-0">Certificates</h3>

        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#newCertificateModal">
          Add
        </button>
      </div>

      <% if @certificates.any? %>
        <% @certificates.each do |cert| %>
          <div class="d-flex justify-content-between align-items-center">
            <p>
              <strong><%= cert.name %></strong> — <%= cert.provider %>
              (<%= cert.issue_date&.strftime('%b %Y') %>)
            </p>

            <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#certificateModal-<%= cert.id %>">
              Edit
            </button>
          </div>
        <% end %>
      <% else %>
        <p class="p-3 text-muted">No certificates yet</p>
      <% end %>

      <!-- EDUCATION -->
      <div class="d-flex justify-content-between align-items-center bg-dark p-4 mb-2">
        <h3 class="text-white text-uppercase mb-0">Education</h3>

        <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#newEducationModal">
          Add
        </button>
      </div>

      <% if @educations.any? %>
        <% @educations.each do |edu| %>
          <div class="d-flex justify-content-between align-items-center">
            <strong><%= edu.institution %></strong>
            <button class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#educationModal-<%= edu.id %>">
              Edit
            </button>
          </div>

          <p>
            <%= edu.degree %> — <%= edu.location %><br>
            <small>
              <%= edu.start_date.year %> - <%= edu.end_date.year %>
            </small>
          </p>
        <% end %>
      <% else %>
        <p class="p-3 text-muted">No education added yet</p>
      <% end %>
    </div>
  </div>
</div>

<%= render "modal/header", profile: @profile %>
<%= render "modal/contact", profile: @profile %>
<%= render "modal/profile", profile: @profile %>
<%= render "modal/skill", profile: @profile %>
<%= render "modal/language", profile: @profile %>

<%= render "modal/experience/new", profile: @profile %>
<% @experiences.each do |exp| %>
  <%= render "modal/experience/edit", profile: @profile, experience: exp %>
<% end %>

<%= render "modal/project/new", profile: @profile %>
<% @projects.each do |project| %>
  <%= render "modal/project/edit", profile: @profile, project: project %>
<% end %>

<%= render "modal/certificate/new", profile: @profile %>
<% @certificates.each do |certificate| %>
  <%= render "modal/certificate/edit", profile: @profile, certificate: certificate %>
<% end %>

<%= render "modal/education/new", profile: @profile %>
<% @educations.each do |education| %>
  <%= render "modal/education/edit", profile: @profile, education: education %>
<% end %>
